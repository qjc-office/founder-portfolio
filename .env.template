# founder-portfolio environment template
# Copy to .env (or merge into ~/.claude/.env.secrets) and fill in.
#
# These vars are ONLY needed if you use the AI portrait generation feature
# (scripts/generate_portrait.py). The core PDF render (scripts/render.py) has
# zero external dependencies.

# OpenAI API key — issued at https://platform.openai.com/api-keys
# Required for generate_portrait.py. Each user provides their own key.
# Powers OpenAI gpt-image-2 (image-to-image), ~$0.04/image (medium quality).
# 5 presets × $0.04 = $0.20 per full portrait set.
OPENAI_API_KEY=

# Optional: Chrome binary override (auto-detected if unset)
# Useful in CI / Docker / non-standard installs
# CHROME_BIN=/usr/bin/chromium-browser

# Optional: Python interpreter override for bootstrap.sh
# Default: python3 (system)
# PYTHON_BIN=/opt/homebrew/bin/python3.12
